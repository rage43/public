{
    "rules": {
        "default_passwords": {
            "enabled": true,
            "priority": 1,
            "description": "MDP par défaut (root, admin, password) - TOP 12"
        },
        "leetspeak": {
            "enabled": true,
            "priority": 10,
            "description": "Substitutions (a→4, e→3)"
        },
        "case_variation": {
            "enabled": true,
            "priority": 20,
            "description": "Variations de casse"
        },
        "numeric_suffix": {
            "enabled": true,
            "priority": 30,
            "description": "Suffixes numériques (1, 123)"
        },
        "special_suffix": {
            "enabled": true,
            "priority": 40,
            "description": "Suffixes spéciaux (!, @) - Max 2"
        },
        "year_suffix": {
            "enabled": true,
            "priority": 50,
            "description": "Années (2024, 2025)"
        },
        "combination": {
            "enabled": false,
            "priority": 5,
            "description": "DÉSACTIVÉ"
        },
        "duplication": {
            "enabled": true,
            "priority": 8,
            "description": "Duplication (demo → demodemo)"
        },
        "hybrid_suffix": {
            "enabled": true,
            "priority": 35,
            "description": "Hybrid (Password@1)"
        },
        "word_concatenation": {
            "enabled": false,
            "priority": 3,
            "description": "Concatène 2 mots du source (activable via --concat)"
        },
        "leet_first_year": {
            "enabled": true,
            "priority": 55,
            "description": "Cap/leet 1ère lettre + année (YY/YYYY) + 1-3 spéciaux identiques (Mot2026***, @ot2026**)"
        },
        "all_yy": {
            "enabled": false,
            "priority": 99,
            "description": "OPT-IN --all-yy : dates de naissance, séparateurs/spéciaux, règle isolée, ~6000 var/mot"
        },
        "case_combo": {
            "enabled": false,
            "priority": 22,
            "description": "OPT-IN --case-combo : capitalisation combinatoire bornée (maj. de 1-2 lettres internes, ex: W0nD3r), chaînée après leetspeak/case_variation"
        }
    },
    "cleanup": {
        "enabled": true,
        "max_special_start": 2,
        "max_special_end": 3,
        "max_special_middle": 2,
        "max_numeric_start": 0,
        "max_numeric_end": 4,
        "max_repeating_chars": 4,
        "min_length": 4,
        "max_length": 14,
        "weak_short_threshold": 6
    },
    "output": {
        "max_passwords": 500000000,
        "max_disk_gb": 5,
        "warn_passwords": 1000000,
        "warn_disk_gb": 1
    },
    "generation": {
        "batch_size": 10000,
        "remove_duplicates": true
    }
}
